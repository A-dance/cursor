{
  "name": "cursor",
  "private": true,
  "description": "Next.js アプリは movie-app です。リポジトリのルートで npm run dev すると movie-app が起動します（Cursor のルートワークスペース向け）。",
  "scripts": {
    "postinstall": "npm install --prefix movie-app",
    "dev": "npm --prefix movie-app run dev -- --hostname 127.0.0.1 --port 3000",
    "build": "npm --prefix movie-app run build",
    "start": "npm --prefix movie-app run start",
    "lint": "npm --prefix movie-app run lint"
  }
}
